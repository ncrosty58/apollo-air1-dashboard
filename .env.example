# Copy to .env and fill in real values before running.

INFLUX_URL=http://192.168.4.113:8086
INFLUX_ORG=cosmoslab
INFLUX_BUCKET=air_quality
# Scoped token for the air_quality bucket (created via the InfluxDB API, not
# the admin token used by the iot stack) -- read+write, since this app both
# reads sensor history and persists Google/PurpleAir live readings so their
# History charts read from this app's own InfluxDB data, same as AirNow/
# OpenWeatherMap, instead of each vendor's own history API. Rotate in the
# InfluxDB UI under Load Data > API Tokens if it ever leaks.
INFLUX_TOKEN=

# Dedicated MQTT client for this app — publishes control commands (buttons,
# switches, numbers) and subscribes to their state topics. cosmos-lab/smarthome/air1
# is the topic_prefix set in apollo-air1-mqtt-esphome's apollo-air1-mqtt.yaml.
MQTT_BROKER=192.168.4.113
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=cosmos-lab/smarthome/air1

# AirNow (https://docs.airnowapi.org/) — outdoor AQI for the "Outside" card.
AIRNOW_API_KEY=
AIRNOW_ZIP=

# Google Air Quality API (https://developers.google.com/maps/documentation/air-quality)
# — optional second provider for the Outside card's AirNow/Google switch.
# Needs the "Air Quality API" enabled on the key in Google Cloud Console.
GOOGLE_AQ_API_KEY=

# PurpleAir API (https://api.purpleair.com/) — optional third provider.
# The nearest outdoor sensor to home is picked automatically; set
# PURPLEAIR_SENSOR_INDEX to pin a specific sensor instead.
PURPLEAIR_API_KEY=
PURPLEAIR_SENSOR_INDEX=

# OpenWeatherMap pollution needs no key here — Node-RED polls it (see the
# Apollo AIR-1 tab) and this app reads the owm_* fields from InfluxDB.
# Set OWM_API_KEY on the *nodered* container to enable that poll.

PORT=5858
FLASK_ENV=production
