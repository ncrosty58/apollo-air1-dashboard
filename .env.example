# Copy to .env and fill in real values before running.

INFLUX_URL=http://192.168.4.113:8086
INFLUX_ORG=cosmoslab
INFLUX_BUCKET=air_quality
# Scoped read-only token for the air_quality bucket (created via the InfluxDB
# API, not the admin token used by the iot stack). This app only ever reads
# from Influx -- every provider's current reading and history is written by
# Node-RED (see the Apollo AIR-1 flow), not by this app. Rotate in the
# InfluxDB UI under Load Data > API Tokens if it ever leaks.
INFLUX_TOKEN=

# Dedicated MQTT client for this app — publishes control commands (buttons,
# switches, numbers) and subscribes to their state topics. cosmos-lab/smarthome/air1
# is the topic_prefix set in apollo-air1-mqtt-esphome's apollo-air1-mqtt.yaml.
MQTT_BROKER=192.168.4.113
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=cosmos-lab/smarthome/air1

# AirNow (https://docs.airnowapi.org/) — outdoor AQI for the "Outside" card.
AIRNOW_API_KEY=
AIRNOW_ZIP=

# Google Air Quality API (https://developers.google.com/maps/documentation/air-quality)
# — used here for the on-demand Forecast feature AND the Away view's live 7-day
# history. Current-reading and history for the Outside card's AirNow/Google/
# PurpleAir switch are polled by Node-RED straight into InfluxDB (see the Apollo
# AIR-1 flow); set this same key as GOOGLE_AQ_API_KEY on the *nodered* container
# too, to enable that poll. Needs the "Air Quality API" enabled on the key.
GOOGLE_AQ_API_KEY=

# PurpleAir — the Home path needs no key here (Node-RED polls the sensor into
# InfluxDB and this app reads it back). But the Away view and the "nearest
# sensor" resolver used when setting a location DO call PurpleAir live from this
# app, so set a read key here to enable them. Same key as the nodered container.
# Leave blank to disable Away/nearest-sensor for PurpleAir (Home still works).
PURPLEAIR_API_KEY=

# OpenWeatherMap — current-reading and history are polled into InfluxDB by
# Node-RED (set OWM_API_KEY on the *nodered* container for that), but the
# on-demand pollution Forecast and the Away view's live 7-day history are
# fetched live by this app, so it needs the key here too. Same key works for
# both. Leave blank to disable those (the current/history OWM provider still
# works without it).
OWM_API_KEY=

PORT=5858
FLASK_ENV=production

# Optional: link to the Grafana provider-comparison dashboard, shown on the
# Technical/Indoor pages only (it's behind Cloudflare Access, so not surfaced
# on the family-facing Simple view). Leave blank to hide the link.
GRAFANA_DASHBOARD_URL=https://grafana.cosmoslab.dev/d/air-quality-providers
