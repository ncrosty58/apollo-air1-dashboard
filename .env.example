# Copy to .env and fill in real values before running.

INFLUX_URL=http://192.168.4.113:8086
INFLUX_ORG=cosmoslab
INFLUX_BUCKET=air_quality
# Scoped read-only token for the air_quality bucket (created via the InfluxDB
# API, not the admin token used by the iot stack). Rotate in the InfluxDB UI
# under Load Data > API Tokens if it ever leaks.
INFLUX_TOKEN=

PORT=5858
FLASK_ENV=production
